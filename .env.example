## DocMind AI .env (copy from this file)
## Nested mapping: DOCMIND_SECTION__FIELD -> settings.section.field

# ============================================================================
# OPTIONAL LOCAL-DEV DOTENV OVERRIDES (ADVANCED; AVOID IN PRODUCTION)
# ============================================================================
#
# By default, exported environment variables win over `.env` for DocMind settings.
# If you want repo `.env` to override exported env vars for DocMind settings:
# DOCMIND_CONFIG__DOTENV_PRIORITY=dotenv_first
#
# To prevent dependencies from using global machine env vars (allowlist only):
# DOCMIND_CONFIG__ENV_MASK_KEYS=OPENAI_API_KEY,ANTHROPIC_API_KEY
#
# To provide compatible env vars for dependencies from validated DocMind settings:
# DOCMIND_CONFIG__ENV_OVERLAY=OPENAI_API_KEY:openai.api_key

# ============================================================================
# CORE APPLICATION SETTINGS (FLAT FORMAT - TOP LEVEL)
# ============================================================================


# Backend configuration (flat - maps to settings.llm_backend)
# Options: ollama | openai_compatible | vllm | lmstudio | llamacpp
DOCMIND_LLM_BACKEND=ollama

## Agents
DOCMIND_AGENTS__DECISION_TIMEOUT=200
DOCMIND_AGENTS__MAX_RETRIES=2

## LLM
# Leave empty to use the selected provider's default model.
DOCMIND_LLM_REQUEST__MODEL=
DOCMIND_LLM_REQUEST__CONTEXT_WINDOW=131072
DOCMIND_LLM_REQUEST__MAX_OUTPUT_TOKENS=2048
DOCMIND_LLM_REQUEST__TEMPERATURE=0.1
DOCMIND_OLLAMA_BASE_URL=http://localhost:11434
# Optional (Ollama Cloud / web search): Bearer API key.
DOCMIND_OLLAMA_API_KEY=
# Optional (Ollama Cloud): enable web_search/web_fetch tool integration (default false).
DOCMIND_OLLAMA_ENABLE_WEB_SEARCH=false
# Optional: request logprobs from Ollama chat (default false).
DOCMIND_OLLAMA_ENABLE_LOGPROBS=false
# Optional: include top-k alternative tokens per position (0-20) when logprobs enabled.
DOCMIND_OLLAMA_TOP_LOGPROBS=0
# llama.cpp server (OpenAI-compatible GGUF runtime).
# Use `llama-server --alias <name>` and set DOCMIND_LLM_REQUEST__MODEL to that
# alias when DOCMIND_LLM_BACKEND=llamacpp.
DOCMIND_LLAMACPP_BASE_URL=http://localhost:8080/v1
DOCMIND_LMSTUDIO_BASE_URL=http://localhost:1234/v1
DOCMIND_VLLM_BASE_URL=http://localhost:8000/v1
# DOCMIND_LLM_REQUEST__MODEL=local-gguf
DOCMIND_OPENAI__API_KEY=not-needed
DOCMIND_OPENAI__API_MODE=chat_completions
DOCMIND_OPENAI__BASE_URL=http://localhost:1234/v1
DOCMIND_OPENAI__DEFAULT_HEADERS={}
DOCMIND_OPENAI__REQUIRE_V1=true
DOCMIND_UI__REQUEST_TIMEOUT_SECONDS=120
DOCMIND_LLM_REQUEST_TIMEOUT_SECONDS=120
DOCMIND_LLM_STREAMING_ENABLED=true

## Embeddings
DOCMIND_EMBEDDING__MODEL_NAME=BAAI/bge-m3
DOCMIND_EMBEDDING__MODEL_REVISION=5617a9f61b028005a4858fdac845db406aefb181
# Optional full local SentenceTransformers snapshot; bypasses model ID/revision.
# DOCMIND_EMBEDDING__LOCAL_MODEL_PATH=/models/bge-m3
DOCMIND_EMBEDDING__CACHE_FOLDER=./models_cache
DOCMIND_EMBEDDING__DIMENSION=1024
DOCMIND_EMBEDDING__MAX_LENGTH=8192
DOCMIND_EMBEDDING__NORMALIZE_TEXT=true
# Optional: set a revision when you configure a custom SigLIP model ID.
# The default model uses the source-controlled revision.
# DOCMIND_EMBEDDING__SIGLIP_MODEL_REVISION=
DOCMIND_EMBEDDING__BATCH_SIZE_TEXT_GPU=12
DOCMIND_EMBEDDING__BATCH_SIZE_TEXT_CPU=4

## Processing
DOCMIND_PROCESSING__CHUNK_SIZE=1024
DOCMIND_PROCESSING__CHUNK_OVERLAP=100
DOCMIND_PROCESSING__MAX_DOCUMENT_SIZE_MB=100
# Export PDF page images (WebP/JPEG) and optionally encrypt them (AES-GCM -> *.enc).
# NOTE: Encryption requires a TWO-STEP setup:
#   1. Set DOCMIND_PROCESSING__ENCRYPT_PAGE_IMAGES=true
#   2. Set DOCMIND_IMG_AES_KEY_BASE64 to a valid base64-encoded 32-byte key (AES-256).
# If the key is empty, encryption is disabled even if the flag is true.
DOCMIND_PROCESSING__ENCRYPT_PAGE_IMAGES=false

## Document parsing and OCR
# Docling, pypdfium2, and RapidOCR form one always-local parser path.
# Prefetch the app-owned Docling bundle; RapidOCR models ship in its locked wheel.
DOCMIND_PARSING__MAX_PAGES=500
DOCMIND_PARSING__MAX_RENDER_PIXELS=40000000
DOCMIND_PARSING__MAX_TOTAL_TEXT_CHARS=10000000
DOCMIND_PARSING__PARSE_TIMEOUT_SECONDS=300
DOCMIND_PARSING__OCRMYPDF_TIMEOUT_SECONDS=300
DOCMIND_PARSING__DIRECT_TEXT_PROBE_BYTES=8192
DOCMIND_PDF_BACKEND__RENDER_DPI=200
DOCMIND_PDF_BACKEND__MIN_TEXT_CHARS_PER_PAGE=24
DOCMIND_PARSING__MODEL_CACHE_DIR=cache/models
DOCMIND_OCR__FORCE_OCR=false
DOCMIND_OCR__OCRMYPDF_JOBS=1
DOCMIND_OCR__SEARCHABLE_PDF_ENABLED=false
# Optional extras:
# - `uv sync --extra searchable-pdf` for OCRmyPDF; install Tesseract language
#   packs through the OS package manager. Searchable-PDF export requires POSIX;
#   use WSL2 on Windows.
# - Prefetch the default retrieval models and Docling layout files with:
#   `uv run python tools/models/pull.py --all --cache_dir ./models_cache --parser-defaults --parser-cache-dir ./cache/models`
#   RapidOCR owns hash-verified models packaged in its locked wheel.
# - Verify dependency and Docling model-manifest integrity with:
#   `uv run python scripts/parser_health.py --check`

## Retrieval
DOCMIND_RETRIEVAL__TOP_K=10
DOCMIND_RETRIEVAL__USE_RERANKING=true
DOCMIND_RETRIEVAL__RERANKING_TOP_K=5
DOCMIND_RETRIEVAL__ENABLE_SERVER_HYBRID=true
## Server-side fusion (Qdrant Query API)
DOCMIND_RETRIEVAL__FUSION_MODE=rrf   # or dbsf when supported
DOCMIND_RETRIEVAL__FUSED_TOP_K=60
DOCMIND_RETRIEVAL__RRF_K=60
## Reranking timeout budgets (milliseconds)
DOCMIND_RETRIEVAL__TEXT_RERANK_TIMEOUT_MS=250
DOCMIND_RETRIEVAL__SIGLIP_TIMEOUT_MS=150
DOCMIND_RETRIEVAL__TOTAL_RERANK_BUDGET_MS=400
DOCMIND_RETRIEVAL__RERANKER_NORMALIZE_SCORES=true
DOCMIND_RETRIEVAL__RERANKER_MODEL=BAAI/bge-reranker-v2-m3
DOCMIND_RETRIEVAL__SIGLIP_BATCH_SIZE=8
DOCMIND_RETRIEVAL__SIGLIP_PRUNE_M=64

## Cache
DOCMIND_CACHE__DIR=./cache
DOCMIND_CACHE__FILENAME=docmind.duckdb

## Database (Qdrant)
DOCMIND_DATABASE__QDRANT_API_KEY=
DOCMIND_DATABASE__QDRANT_COLLECTION=docmind_docs
# Dedicated collection for SigLIP PDF page-image vectors (created automatically if missing)
DOCMIND_DATABASE__QDRANT_IMAGE_COLLECTION=docmind_images
DOCMIND_DATABASE__QDRANT_TIMEOUT=60
DOCMIND_DATABASE__QDRANT_URL=http://localhost:6333

## Artifact storage (content-addressed; stores page images/thumbnails by sha256)
# DOCMIND_ARTIFACTS__DIR=./data/artifacts

## Hardware acceleration
DOCMIND_ENABLE_GPU_ACCELERATION=true
## Hashing / canonicalization
DOCMIND_HASHING__HMAC_SECRET=change-me-please-to-a-unique-32-byte-secret-1234
## Security
DOCMIND_SECURITY__ALLOW_REMOTE_ENDPOINTS=false
# Add entries as URLs or hostnames; hostnames are matched case-insensitively.
DOCMIND_SECURITY__ENDPOINT_ALLOWLIST=["http://localhost","https://localhost","http://127.0.0.1","https://127.0.0.1"]
DOCMIND_SECURITY__TRUST_REMOTE_CODE=false

## Chat memory & analysis modes
DOCMIND_CHAT__SQLITE_PATH=./data/chat.db
DOCMIND_ANALYSIS__MODE=auto
DOCMIND_ANALYSIS__MAX_WORKERS=4

## GraphRAG
# Default state of the per-ingestion GraphRAG control
DOCMIND_GRAPHRAG_CFG__ENABLED=false
DOCMIND_GRAPHRAG_CFG__AUTOLOAD_POLICY=latest_non_stale
DOCMIND_GRAPHRAG_CFG__DEFAULT_PATH_DEPTH=1
DOCMIND_GRAPHRAG_CFG__EXPORT_SEED_CAP=32

# PyTorch and CUDA configuration
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512
TOKENIZERS_PARALLELISM=false
CUDA_VISIBLE_DEVICES=0
NVIDIA_VISIBLE_DEVICES=all
CUDA_HOME=/usr/local/cuda

# Offline operation (pre-download models to use)
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# Observability / OpenTelemetry (SPEC-012)
DOCMIND_OBSERVABILITY__ENABLED=false
# When enabled, configure protocol and endpoint as needed:
# DOCMIND_OBSERVABILITY__PROTOCOL=http/protobuf
# DOCMIND_OBSERVABILITY__ENDPOINT=http://localhost:4318

# Optional AES-GCM key for encrypting page images (.enc); base64-encoded 32B key
DOCMIND_IMG_AES_KEY_BASE64=
DOCMIND_IMG_KID=local-key-1
DOCMIND_IMG_DELETE_PLAINTEXT=false

## FILE SYSTEM & PERSISTENCE (FLAT FORMAT - TOP LEVEL)
## Data directory (flat - maps to settings.data_dir; cache uses DOCMIND_CACHE__DIR)
DOCMIND_DATA_DIR=./data

# Logging (flat - maps to settings.log_file and settings.log_level)
DOCMIND_LOG_FILE=./logs/docmind.log
DOCMIND_LOG_LEVEL=INFO
